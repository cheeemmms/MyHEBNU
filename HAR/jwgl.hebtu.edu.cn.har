          "content": {
            "size": 10657,
            "mimeType": "application/javascript",
            "text": "(function(a) {\r\n\r\n    function ck(f) {\r\n        if(f >= 48 && f <= 57) {\r\n            return 1\r\n        }\r\n        if(f >= 65 && f <= 90) {\r\n            return 2\r\n        }\r\n        if(f >= 97 && f <= 122) {\r\n            return 4\r\n        } else {\r\n            return 8\r\n        }\r\n    }\r\n\t\r\n\r\n\r\n    function cck(a){\r\n        var b = 0;\r\n        for (i = 0; i < a.length; i++) {\r\n            var singleChar = a.charCodeAt(i);\r\n            //满足只是一个数字\r\n            if ((b & 1) != 1 && (ck(singleChar) & 1) == 1) {\r\n                b |= 1;\r\n                continue;\r\n            }\r\n            if ((b & 2) != 2 && (ck(singleChar) & 2) == 2) {\r\n                b |= 2;\r\n                continue;\r\n            }\r\n            if ((b & 4) != 4 && (ck(singleChar) & 4) == 4) {\r\n                b |= 4;\r\n                continue;\r\n            }\r\n            if ((b & 8) != 8 && (ck(singleChar) & 8) == 8) {\r\n                b |= 8;\r\n            }\r\n        }\r\n        //0111,1011,1101,1110,1111\r\n        //var passArr = [14,13,11,7,15];\r\n        //四种全满足:1111\r\n        var passArr = [15];\r\n        for (i = 0; i < passArr.length; i++) {\r\n            if(b==passArr[i]){\r\n                return 1;\r\n            }\r\n        }\r\n        return 0;\r\n    }\r\n\t\r\n    function k(a) {\r\n\t\tvar flag = $(\"#sfcyxmmkl\").val();\r\n\t\tvar min = $(\"#min\").val();\r\n\t\tvar max = $(\"#max\").val();\r\n\t\tvar yhm=$(\"#yhm\").val().toLowerCase();\r\n\t\tif(flag==1){\r\n            if (a == null || a.length < min || a.length > max) {\r\n                return 1;\r\n            } else if (a.toLowerCase().indexOf(yhm) > -1) {\r\n                return 1;\r\n            } else if (checkKeyBoardChar(a.toLowerCase())) {\r\n                return 1;\r\n            } else if(cck(a)==0) {\r\n                return 1;\r\n            }else{\r\n                return 3;\r\n            }\r\n\t\t}else 