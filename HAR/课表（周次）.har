          "content": {
            "size": 1318,
            "mimeType": "text/css",
            "text": ".by_form{\n\n}\n.hiddenBox{\n    display: none;\n}\n.row-content{\n  /* display: flex;\n  flex-wrap: wrap; */\n}\n.openClose{\n  cursor: pointer;\n}\n.openClose label{\n  color:#337ab7;\n}\n.openClose .openBtn,.openClose .closeBtn{\n  text-align: center;\n  cursor: pointer;\n}\n.openClose .img-box img{\n  width: 13px;\n  height: 10px;\n  margin-left: 5px;\n}\n.openClose .img-box .sq{\n  transform: rotate(180deg);\n}\n.side-box .opt-zk{\n  display: inline-block;\n  margin-right: 10px;\n}\n.side-box .dyBtn{\n  margin-left: 10px;\n}\n\n.opt-box button{\n  /* margin-left: 15px;\n  margin-right: 15px; */\n}\n.opt-box{\n  display:flex;\n  align-items: center;\n  justify-content: space-between;\n}\n.opt-box .right-box{\n  display:flex;\n  align-items: center;\n  flex-wrap: nowrap;\n\n}\n.dyBtn .ic-spt{\n  position: absolute;\n  top: -31px;\n  left: -44px;\n  padding: 2px 5px;\n  background: #8d8d8d;\n  border-radius: 4px;\n  color: #fff;\n  font-size: 12px;\n  white-space: nowrap;\n  display: none;\n\n}\n.dyBtn:hover .ic-spt{\n  display: block;\n}\n.dyBtn .ic-spt::before{\n  content: '';\n  position: absolute;\n  width: 0;\n  height: 0;\n  border-left: 4px solid transparent;\n  border-right: 4px solid transparent;\n  border-top: 4px solid #8d8d8d;\n  top: 20px;\n  left: 40px;\n}\n\n.wztjBox>div{\n  margin-bottom: 8px;\n\n}\n.wztjBox .glyphicon{\n  padding-top: 7px;\n  cursor: pointer;\n\n}"
