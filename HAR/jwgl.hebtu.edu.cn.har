t</div>\n\t\t\t\t<div class=\"col-md-7\">\n\t\t\t\t\t \n\t\t\t\t\t\n\t\t\t\t\t\t<div class=\"index_rctx\" id=\"area_two\"></div>\n\t\t\t\t\t\n\t\t\t\t</div>\n\t\t\t\t<div class=\"col-md-5\">\n\t\t\t\t\t<div class=\"index_rctx\" id=\"area_three\"></div>\n\t\t\t\t</div>\n\t\t\t\t<div class=\"col-md-7\">\n\t\t\t\t\t<div class=\"index_rctx\" id=\"area_four\"></div>\n\t\t\t\t</div>\n\t\t\t</div>\n\t\t</div>\n\t</div>\n\t\n</div>\n\n<!-- footer -->\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n<!-- footer --> \r\n\r\n<div id=\"footerID\" class=\"footer\"  style=\"background-color: \" >\r\n\t\r\n\t<p>版权所有&#169; Copyright 河北师范大学&nbsp;&nbsp;&nbsp;版本V-9.0</p>\r\n</div>\r\n\r\n\r\n\r\n\r\n<script  type=\"text/javascript\">\r\n\t//系统中页面底部的时间随系统时间来定\r\n\t/* var date=new Date;\r\n\tvar year=date.getFullYear();\r\n\tvar s = $(\"#footerID\").text().indexOf('-');\r\n\tvar textNr =$(\"#footerID\").text().substr(0,s+1)+year+$(\"#footerID\").text().substr(s+5);\r\n\t$(\"#footerID\").text(\"\");\r\n\t$(\"#footerID\").text(textNr); */\r\n\r\n</script>\r\n<!-- footer-end -->\n<!-- footer-end -->\n\r\n</body>\r\n\n\n\n<!--jQuery.jqGrid -->\r\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/zftal-ui-v5-1.0.2/assets/plugins/jqGrid/css/jquery.jqgrid.css?ver=20170713\" />\r\n<script type=\"text/javascript\" src=\"/zftal-ui-v5-1.0.2/assets/plugins/jqGrid/jquery.jqgrid.src-min.js?ver=20170713\" charset=\"utf-8\"></script>\r\n<script type=\"text/javascript\" src=\"/zftal-ui-v5-1.0.2/assets/plugins/jqGrid/jquery.jqgrid.contact-min.js?ver=20170713\" charset=\"utf-8\"></script>\r\n<script type=\"text/javascript\" src=\"/zftal-ui-v5-1.0.2/assets/plugins/jqGrid/lang/zh_CN.js?ver=20170713\" charset=\"utf-8\"></script>\r\n<script type=\"text/javascript\" src=\"/js/plugins/jqGrid4.6/jquery.jqgrid.settings.js?ver=20170713\" charset=\"utf-8\"></script>\r\n<script type=\"text/javascript\" src=\"/js/plugins/jqGrid4.6/jquery.jqGrid-min.js?ver=20170713\" charset=\"utf-8\"></script>\n<!--jQuery浏览器检测 -->\n<!--jQuery.validation -->\n<link rel=\"stylesheet\" type=\"text/css\" href=\"/zftal-ui-v5-1.0.2/assets/plugins/validation/css/jquery.validate-min.css?ver=20170713\" />\n<script type=\"text/javascript\" src=\"/zftal-ui-v5-1.0.2/assets/plugins/validation/js/jquery.validate-min.js?ver=20170713\" charset=\"utf-8\"></script>\n<script type=\"text/javascript\" src=\"/zftal-ui-v5-1.0.2/assets/plugins/validation/js/jquery.validate.contact-min.js?ver=20170713\" charset=\"utf-8\"></script>\n<script type=\"text/javascript\" src=\"/zftal-ui-v5-1.0.2/assets/plugins/validation/js/jquery.validate.methods.contact-min.js?ver=20170713\" charset=\"utf-8\"></script>\n<script type=\"text/javascript\" src=\"/zftal-ui-v5-1.0.2/assets/plugins/validation/lang/zh_CN-min.js?ver=20170713\" charset=\"utf-8\"></script>\n<script type=\"text/javascript\">\n\tjQuery(function($){\n\t\t$('[data-toggle*=\"validation\"]').trigger(\"validation\");\n\t});\n</script>\n\n<!-- 软件评价相应ini文件引用-->\n\r\n\n<!-- 人工智能相应ini文件引用-->\n\n\n<!-- 即时通讯ini文件引用-->\n\n\n<script type='text/javascript' src=\"/zftal-ui-v5-1.0.2/assets/plugins/crypto/rsa/jsbn.js?ver=20170713\"></script>\r\n<script type='text/javascript' src=\"/zftal-ui-v5-1.0.2/assets/plugins/crypto/rsa/prng4.js?ver=20170713\"></script>\r\n<script type='text/javascript' src=\"/zftal-ui-v5-1.0.2/assets/plugins/crypto/rsa/rng.js?ver=20170713\"></script>\r\n<script type='text/javascript' src=\"/zftal-ui-v5-1.0.2/assets/plugins/crypto/rsa/rsa.js?ver=20170713\"></script>\r\n<script type='text/javascript' src=\"/zftal-ui-v5-1.0.2/assets/plugins/crypto/rsa/base64.js?ver=20170713\"></script>\n<script type=\"text/javascript\" src=\"/js/globalweb/comp/xtgl/disk.js?ver=20170713\"></script>\n<script type=\"text/javascript\" src=\"/js/globalweb/comp/xtgl/device.js?ver=20170713\"></script>\n<script type=\"text/javascript\" src=\"/js/globalweb/comp/xtgl/index_v5.js?ver=20170713\"></script>\n<script type=\"text/javascript\" src=\"/js/globalweb/comp/xtgl/jwglxt_index.js?ver=20170713\"></script>\n\n\n\n<script type=\"text/javascript\">\n var tabsList = [];\n var iframeList = ['index']\nvar currExpand = null\nvar activeAid = null\n var gnmkdmAndAidmap= {};\n\nfunction ifFun(){\n\t// 获取 iframe 元素\n\tsetTimeout(function(){\n\t\tvar iframeT = $('.iframe-inner-'+ activeAid);\n\t\tvar iframes = $('.iframe-inner');\n\n\n\t\t// var iframeDocument = iframeT.contentDocument || iframeT.contentWindow.document; //报错\n\t\t// var divElement = iframeDocument.querySelector('#btn_box .btn-toolbar');\n\t\t// console.log(divElement,'divElement=')\n\n\t\t// if(!$('.iframe-inner-'+ activeAid + '.bootbox').hasClass('box-full-screen')){\n\t\t// \tconsole.log('hahahah')\n\t\t// \t$('.iframe-inner-'+ activeAid + '.bootbox').addClass('box-full-screen')\n\t\t// }\n\t\t// if(!$('.iframe-inner-'+ activeAid + '.bootbox-full .fa').hasClass('fa-minus-square-o')){\n\t\t// \t$('.iframe-inner-'+ activeAid + '.bootbox-full .fa').addClass('fa-minus-square-o').removeClass('fa-square')\n\t\t// }\n\t\t// $('.modal-dialog').css('left',0)\n\t},800)\n\n}\n$(document).ready(function() {\n  // 假设这是动态生成的标签数据\n//   var tabs = ['Tab 1', 'Tab 2', 'Tab 3', 'Tab 4', 'Tab 5', 'Tab 6', 'Tab 7', 'Tab 8', 'Tab 9'];\n\n\t// 更多按钮点击事件\n\t$(document).off('click','.tab-overflow').on('click','.tab-overflow', function(e){\n\t\tif($(this).hasClass('show-more')){\n\t\t\t$(this).removeClass('show-more')\n\t\t}else{\n\t\t\t$(this).addClass('show-more')\n\t\t}\n\t\te.stopPropagation();\n\t});\n\n\n\t// 点击页面其他位置关闭下拉\n\t$(document).on('click', function() {\n\t\t$('.tab-overflow').removeClass('show-more');\n\t});\n\n  // 窗口大小改变时重新计算\n  $(window).resize(function() {\n    checkTabOverflow();\n  });\n\n    var cjxgtctx = $(\"#cjxgtctx\").val();\n\tif (cjxgtctx == 1) {\n\t\t$.alert(\"您的成绩有变更，请及时查看\", function() {\n\t\t\t// 调用后端接口删除/标记提醒记录\n\t\t\t$.ajax({\n\t\t\t\turl: _path + \"/xtgl/index_scCjxgtctx.html\", // 后端接口地址\n\t\t\t\ttype: \"POST\",\n\t\t\t\tsuccess: function() {\n\t\t\t\t\tconsole.log(\"提醒记录已删除\");\n\t\t\t\t},\n\t\t\t\terror: function() {\n\t\t\t\t\tconsole.error(\"请求失败\");\n\t\t\t\t}\n\t\t\t});\n\t\t});\n\t}\n});\n\nfunction initTabs(tabsList) {\n  var $tabsContainer = $('.iframe-tabs');\n  var $tabDropdown = $('.tab-dropdown');\n\n  // 清空容器\n  $tabsContainer.empty();\n  $tabDropdown.empty();\n\n  // 添加所有标签\n  tabsList.forEach((item, index) => {\n\tvar $tab = $('<div class=\"iframe-tab-item iframe-tab-' + item.aid + '\" data-aid=\"' + item.aid + '\">'+\n\t\t\t\t'<span class=\"tab-text tab-text-' + item.aid + '\">' + item.name + '</span>'+\n\t\t\t\t'<span class=\"close-tab close-tab-' + item.aid + '\" data-aid=\"' + item.aid + '\">x</span>'+\n\t\t\t\t'<div class=\"close-box\"><div class=\"close-all\">关闭全部</div><div class=\"close-left\">关闭左侧</div><div class=\"close-right\">关闭右边</div></div>'+\n\t\t\t\t'</div>');\n    $tabsContainer.append($tab);\n    // 克隆一份用于下拉菜单\n    var $dropdownTab = $tab.clone();\n    $tabDropdown.append($dropdownTab);\n  });\n\n  setTimeout(function(){\n\t$('.iframe-tab-item').css('background', '#FFF');\n\t$('.tab-container .iframe-tab-' + activeAid + '').css('background', '#e2f1ff');\n  })\n\n  // 初始检查溢出\n  checkTabOverflow();\n}\n\nfunction checkTabOverflow() {\n  var $tabWrapper = $('.tab-wrapper');\n  var $tabsContainer = $('.iframe-tabs');\n  var $tabOverflow = $('.tab-overflow');\n  var $tabDropdown = $('.tab-dropdown');\n\n  // 重置状态\n  $tabOverflow.hide();\n  $tabsContainer.children().show().appendTo($tabsContainer);\n  $tabDropdown.empty();\n\n  // 获取容器宽度\n  var containerWidth = $tabWrapper.width();\n  let totalWidth = 0;\n  let visibleTabs = [];\n  let hiddenTabs = [];\n\n  // 计算可见标签\n  $tabsContainer.children().each(function() {\n    var $tab = $(this);\n    var tabWidth = $tab.outerWidth(true);\n\n    if (totalWidth + tabWidth + 30 <= containerWidth) { // 40是留给更多按钮的空间\n      totalWidth += tabWidth;\n      visibleTabs.push($tab);\n    } else {\n      hiddenTabs.push($tab);\n    }\n  });\n\n  // 如果有隐藏的标签，显示更多按钮\n  if (hiddenTabs.length > 0) {\n    $tabOverflow.show();\n\n    // 移动隐藏标签到下拉菜单\n    hiddenTabs.forEach($tab => {\n    //   $tab.hide();\n      $tab.clone().appendTo($tabDropdown);\n    });\n\n    // 确保最后一个可见标签不被截断\n    while (visibleTabs.length > 0 && totalWidth > containerWidth - 40) {\n      var $lastTab = visibleTabs.pop();\n      totalWidth -= $lastTab.outerWidth(true);\n      $lastTab.hide();\n      $lastTab.clone().appendTo($tabDropdown);\n    }\n  }\n}\n\n\n\n$(function() {\n\t$(document).off('click', '#js_btn').on('click', '#js_btn', function(e) {\n\t     $(\"#myDiv\").css(\"display\",\"\");\n\t});\n\tlocalStorage.setItem('language',$(\"#localChange\").val());//把值放入localStorage\n\tif($(\"#localChange\").val()=='en_US'){//切换系统名称为英文的\n\t\t$(\"#xtmc\").text(\"Teaching integrated information service platform\");\n\t\t$(\"title\").text(\"Teaching integrated information service platform\")\n\t\t$(\"a.zh\").hide();\n\t\t$(\"a.en\").show();\n\t}else{\n\t\t$(\"a.zh\").show();\n\t\t$(\"a.en\").hide();\n\t}\n});\n\nfunction changePage(pageStyle){\n\twindow.location.href=_path+'/xtgl/index_initMenu.html?pageStyle='+pageStyle;\n}\n\nfunction changePage_lc(pageStyle){\n\t//window.location.href=_path+'/lcgl/lcgl_cxTzlj.html?pageStyle='+pageStyle;\n\t//新开标签页\n\t$.post(_path+'/lcgl/lcgl_cxTzlj.html?gnmkdm=N0261',function(data){\n\t\tif(data.indexOf(\"未配置角色流程向导\") > -1){\n\t\t\t$.alert(\"未配置角色流程向导!\");\n\t\t}else{\n\t\t\twindow.open(_stylePath+\"/flowChart/#/\"+data);\n\t\t}\n\t});\n}\n\nfunction changePage_lcsj(pageStyle){\n\t//window.location.href=_path+'/lcgl/lcgl_cxTzlj.html?pageStyle='+pageStyle;\n\t//新开标签页\n\t$.post(_path+'/lcgl/lcgl_cxTzlj_design.html?gnmkdm=N0261',function(data){\n\t\tif(data.indexOf(\"权限不足\") > -1){\n\t\t\t$.alert(\"权限不足!\");\n\t\t}else{\n\t\t\twindow.open(_stylePath+\"/flowChart/#/\"+data);\n\t\t}\n\t});\n}\n\n\nif($(\"#info\").val() != \"\" && $.trim($(\"#info\").val()).length != 0){\n\tif($(\"#info\").val().indexOf(\"欠费\")>-1){\n\t\t$.alert($(\"#info\").val());\n\t}else{\n\t\t$.success($(\"#info\").val());\n\t}\n}\n\n//是否开启硬盘序列号绑定访问限制\nif(\"1\" == $(\"#sfkqypxlhbdfwxz\").val()){\n\tvar diskLicence=getDiskLicence();\n\tconsole.log(\"diskLicence:\"+diskLicence);\n\tif(diskLicence!=null&diskLicence!=''){\n\t\tjQuery.ajaxSetup({async:false});\n\t\t$.post(_path + \"/xtgl/index_setDiskLicence.html?diskLicence=\"+diskLicence,function(){},'json');\n\t\tjQuery.ajaxSetup({async:true});\n\t}\n}\n\n//定时器定时发送请求更新登录状态信息\nif(\"1\" == $(\"#sftjdlztxx\").val()){\n\tvar int=self.setInterval(\"clock()\",$(\"#dstjdlztsj\").val()* 1000 * 60);\n\tfunction clock(){\n\t\tjQuery.ajaxSetup({async:false});\n\t\t$.post(_path + \"/xtgl/index_cxGxDlztxx.html?dlztxxtj_id=\"+$(\"#dlztxxtj_id\").val(),function(){},'json');\n\t\tjQuery.ajaxSetup({async:true});\n\t}\n}\nif(\"1\"==$(\"#xssymxjyjtxfs\").val()){\n\tif(\"0\"==$(\"#xsxjyjqrzt\").val()){\n\t\tif($(\"#xsXyyjcs\").val() && $(\"#xsXyyjcs\").val()!=0){\n\t\t\tgetXsxjyj();\n\t\t}\n\t}\n}else{\n\tgetXsxkzt();\t//选课业务选择判断(演示用)\n\tgetSytxzt();\t//首页提醒状态\n}\n if(\"1\"==$(\"#xsxyjdtx\").val()){\n\t getXsxyjd();\n }else{\n\t getXsxkzt();\t//选课业务选择判断(演示用)\n\t getSytxzt();\t//首页提醒状态\n }\n//判断是否强制设置密保信息\nif(\"1\"==$(\"#sfqztxmb\").val()&&!\"1\"==$(\"#mbtxqk\").val()){\n\t$.alert(\"请填写密保问题!\",function(){\n\t\t$(\"#updateGrxx\").click();\n\t});\n}\n\n//判断是否强制设置手机号\nif(\"1\"==$(\"#sfqzbdsj\").val()&&!\"1\"==$(\"#sjbdqk\").val()){\n\t$.alert(\"请绑定手机号码!\",function(){\n\t\t$(\"#updateGrxx\").click();\n\t});\n}\n\nvar menuRes = []\n\nif ('1' === '2' || '1' === 2) {\n\t$.post(_path + \"/xtgl/index_cxMenuList.html\",{},function(data){\n\t\tmenuRes = data\n\n\t\tfor (var i = 0; i < menuRes.length; i++) {\n\t\t\tif (menuRes[i].role === 'button' && menuRes[i].gnmkdm) {\n\t\t\t\tmenuRes[i].url = menuRes[i].url + (menuRes[i].url.indexOf('?') === -1 ? '?' : '&') + 'gnmkdm=' + menuRes[i].gnmkdm  + '&layout=default'\n\t\t\t}\n\t\t\tif (menuRes[i].propertyIsEnumerable('children')) {\n\t\t\t\tfor (var j = 0; j < menuRes[i].children.length; j++) {\n\t\t\