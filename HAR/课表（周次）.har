            "text": "//显示字段\nvar xszd = {'sj':true, 'cd': true, 'js':true, 'jszc': false, 'jxb': false};\nvar xkkg=true;\nvar jfckbkg=true;\nvar kblen=1;\nvar sjklen=1;\nvar haveXX=1;\nvar xsxx;\n$(function(){ \n\tfunction paramMapx(){\n\t\tvar map = {};\t\n\t\tmap[\"xnm\"] = $('#xnm').val();\n\t\tmap[\"xqm\"] = $('#xqm').val();\n\t\tif(jQuery(\"input[name=radio1]:checked\").val()=='1'){\n\t\t\tmap[\"zs\"] = jQuery('#zs').val();\n\t\t}\n\t\tmap[\"kblx\"]=jQuery(\"input[name=radio1]:checked\").val();\n\t\tmap[\"doType\"] = 'app';\n\t\tmap['xh'] = $(\"#xh\").val()||'';\n\t\treturn map;\n\t}\n\tvar map = paramMapx();\n\tcxKbContent(map, xszd);\n\t\n\t$('button[data-toggle=\"tab\"]').click(function(e) {\n\t\t$('button[data-toggle=\"tab\"]').removeClass(\"btn-primary\");\n\t\t$(this).addClass(\"btn-primary\");\n\t\t$('#shcPDF').attr('data-type', $(this).attr('data-type'));\n\t});\t\t\n\t\n\t$('#shcPDF').click(function(){\n//\t\tif(haveXX==0){\n//\t\t\t$.alert(\"无您的基本信息，请与管理员联系！\");\n//\t\t\treturn false;\n//\t\t}\n//\t\tif(kblen==0 && xkkg && sjklen == 0){ //如果没有课表数据06-29日\n//\t\t\t$.alert(\"该学年学期尚无您的课表！\");\n//\t\t\treturn false;\n//\t\t}\n//\t\tif(!xkkg){\n//\t\t\t$.alert(\"该学年学期的课表尚未开放！\");\n//\t\t\treturn false;\n//\t\t}\n//\t\tif(!jfckbkg){\n//\t\t\t$.alert(\"缴费后可查询！\");\n//\t\t\treturn false;\n//\t\t}\n\t\tif(haveXX==0){\n\t\t\t$.alert($.i18n.get(\"no-xsxx\"));\n\t\t\treturn false;\n\t\t}\n\t\tif(kblen==0 && xkkg && jfckbkg && sjklen == 0 && jxhjkclen == 0){ //如果没有课表数据06-29日\n\t\t\t$.alert($.i18n.get(\"no-kbxx\"));\n\t\t\treturn false;\n\t\t}\n\t\tif(!xkkg){\n\t\t\t$.alert($.i18n.get(\"no-kbkfxx\"));\n\t\t\treturn false;\n\t\t}\n\t\tif(!jfckbkg){\n\t\t\t$.alert($.i18n.get(\"jfhkcx\"));\n\t\t\treturn false;\n\t\t}\n\t});\n\t$.ajaxSetup({async:true});\n\t$('.weui-navbar__item').on('click', function () {\n\t\t$(this).addClass('weui-bar__item_on').siblings('.weui-bar__item_on').removeClass('weui-bar__item_on');\n\t\tfunction paramMap3(){\n\t\t\tvar map = {};\t\n\t\t\tmap[\"xnm\"] = $('#xnm').val();\n\t\t\tmap[\"xqm\"] = $('#xqm').val();\n\t\t\treturn map;\n\t\t}\n\t\tcxKbContent(paramMap3(),xszd);\n\t});\n\t$.ajaxSetup({async:false});\n\t\n\t//$('#zcview').hide();\n\t\n\t$.init();\n\n});\n\nfunction paramMap(){\n\tvar map = {};\t\n\tmap[\"xnm\"] = $('#xnm').val();\n\tif(jQuery(\"input[name=radio1]:checked\").val()=='1'){\n\t\tmap[\"zs\"] = jQuery('#zs').val();\n\t}\n\tmap[\"doType\"]='app';\n\tmap[\"xqm\"] = $('#xqm').val();\n\tmap[\"kblx\"]=jQuery(\"input[name=radio1]:checked\").val();\n\tmap['xh'] = $(\"#xh\").val()||'';\n\treturn map;\n}\n\n\n\tfunction cxKbContent(map, xszd){\n\t\n\tif($(\"#sfbczc\").val()=='0'){\n\t\t$(\"#table1\").append(\"<h2 class='align-center'><i class='weui_icon_info'><span style = 'font-size:20px;'>因未完成缴费注册，无法查询课表。请尽快完成缴费注册手续！</span></i></h2>\");\n\t\t$(\"#myTab\").css(\"display\",\"none\");\n\t\treturn false;\n\t}\n\t$(\"#table1\").empty();\n\t$.ajax({\n\t\ttype: 'POST', \n\t\turl:_path+'/kbcx/xskbcxMobile_cxXsKb.html',\n\t\tasync: false,\n\t\tdata: map, \n\t\tsuccess: function(data){\n\t\t\tvar xxdm=$(\"#xxdm\").val();\n\t\t\tvar kblx = data.kblx; //获取课表类型\n\t\t\txkkg = data.xkkg; //选课开关\n\t\t\tjfckbkg = data.jfckbkg; //选课开关\n\t\t\tif(!$.defined(data.xsxx)){\n\t\t\t\thaveXX=0;\n\t\t\t\t$(\"#table1\").append(\"<h2 class='align-center'><i class='weui_icon_info'><span style = 'font-size:20px;'>\"+$.i18n.get(\"no-zcxx\")+\"</span></i></h2>\");\n\t\t\t\t$(\"#myTab\").css(\"display\",\"none\");\n\t\t\t\treturn false;\n\t\t\t}else{\n\t\t\t\thaveXX=1;\n\t\t\t}\n\t\t\tif(!data.sjfwkg){\n\t\t\t\t$(\"#table1\").append(\"<h2 class='align-center'><i class='weui_icon_info'><span style = 'font-size:20px;'>不是您学生学院的学生，无法查看！</span></i></h2>\");\n\t\t\t\t$(\"#myTab\").css(\"display\",\"none\");\n\t\t\t\treturn false;\n\t\t\t}\n\t\t\tvar zckbsfxssj=data.zckbsfxssj;\n\t\t\txsxx = data.xsxx; //获取学生信息 姓名学院学年学期学号\n\t\t\tvar qsxqj=data.qsxqj;\n\t\t\tvar kbList = data.kbList||[]; //获取课表数据\n\t\t\tvar rqxx = data.rqazcList;\n\t\t\tvar sjkList = data.sjkList||[];//获取实践课数据\n\t\t\tvar xsxxdm = xsxx.XXDM||'';\n\t\t\tkblen = kbList.length;\n\t\t\tsjklen = sjkList.length;\n \t\t\tif(kblen==0 && xkkg && jfckbkg && sjklen == 0){ //如果没有课表数据\n \t\t\t\t$(\"#table1\").append(\"<h2 class='align-center'><i class='weui_icon_info'><span style = 'font-size:20px;'>\"+$.i18n.get(\"kbcxwk\")+\"</span></i></h2>\");\n\t\t\t\t$(\"#myTab\").css(\"display\",\"none\");\n\t\t\t\treturn false;\n\t\t\t}else if(!xkkg){\n\t\t\t\t$(\"#table1\").append(\"<h2 class='align-center'><i class='weui_icon_info'><span style = 'font-size:20px;'>\"+$.i18n.get(\"no-kbkfxx\")+\"</span></i></h2>\");\n\t\t\t\t$(\"#myTab\").css(\"display\",\"none\");\n\t\t\t\treturn false;\n\t\t\t}else if(!jfckbkg){\n\t\t\t\t$(\"#table1\").append(\"<h3 class='align-center'><div class='nodata'><span>\"+$.i18n.get(\"jfhkcx\")+\"</span></div></h3>\");\n\t\t\t\t$(\"#table2\").append(\"<h3 class='align-center'><div class='nodata'><span>\"+$.i18n.get(\"jfhkcx\")+\"</span></div></h3>\");\n\t\t\t\treturn false;\n\t\t\t}\n \t\t\tvar prop=$(\".weui-bar__item_on\").prop(\"id\");\n \t\t\tvar html = '';\n\n \t\t\t//课表不为空\n \t\t\tvar count = 1;\n\t\t\tfor(var i=0; i<kbList.length; i+=1){\n\t\t\t\tvar xqh_id = kbList[i].xqh_id; //校区号\n\t\t\t\tif(!$.founded(xqh_id)){\n\t\t\t\t\tcontinue;\n\t\t\t\t}\n\t\t\t\t$.ajax({\n\t\t\t\t\ttype: 'POST', \n\t\t\t\t\turl: _path+'/kbcx/xskbcxMobile_cxRsd.html',\n\t\t\t\t\tasync: false,\n\t\t\t\t\tdata: {\"xnm\":$('#xnm').val(), \"xqm\":$('#xqm').val(), \"xqh_id\": xqh_id},\n\t\t\t\t\tdatatype: 'json',\n\t\t\t\t\tsuccess: function(data){\n\t\t\t\t\t\tif(!$.founded(data)){\n\t\t\t\t\t\t\treturn false;\n\t\t\t\t\t\t}\n\t\t\t\t\t\tvar kbrsd = data; //获得日时段数据\n\t\t\t\t\t\tvar html_table = '';\n\t\t\t\t\t\tvar status = 1;\n\t\t\t\t\t\tvar rsdzjsCount = 0;\n\t\t\t\t\t\t$.each(kbrsd, function(index, item){\n\t\t\t\t\t\t\tvar rsdzjs = item.rsdzjs;\n\t\t\t\t\t\t\trsdzjsCount += parseInt(rsdzjs);\n\t\t\t\t\t\t});\n\t\t\t\t\t\t$.ajax({\n\t\t\t\t\t\t\ttype: 'POST', \n\t\t\t\t\t\t\turl: _path+'/jzgl/skxxMobile_cxRsdjc.html',\n\t\t\t\t\t\t\tasync: false,\n\t\t\t\t\t\t\tdata: {\"xnm\":$('#xnm').val(), \"xqm\":$('#xqm').val(), \"xqh_id\": xqh_id},\n\t\t\t\t\t\t\tdatatype: 'json',\n\t\t\t\t\t\t\tsuccess: function(data){\n\t\t\t\t\t\t\t\tif(!$.founded(data)){\n\t\t\t\t\t\t\t\t\treturn false;\n\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t\tsksj = data; //获得数据\n\t\t\t\t\t\t\t\tvar qsjc = 0;\n\t\t\t\t\t\t\t\tif($(\"#zckbsfxsrsd\").val()=='1' && jQuery(\"input[name=radio1]:checked\").val()=='1'){\n\t\t\t\t\t\t\t\t\t$.each(kbrsd, function(index, item){\n\t\t\t\t\t\t\t\t\t\tvar rsdzjs = item.rsdzjs;\n\t\t\t\t\t\t\t\t\t\tvar rsdmc = item.rsdmc;\n\t\t\t\t\t\t\t\t\t\tfor(var k = 1; k <= rsdzjs; k++){\n\t\t\t\t\t\t\t\t\t\t\thtml_table+=\"<tr>\";\n\t\t\t\t\t\t\t\t\t\t\tif(k==1){\n\t\t\t\t\t\t\t\t\t\t\t\thtml_table+=\"<td rowspan='\"+rsdzjs+\"'><span class='time'>\"+rsdmc+\"</span></td>\";\n\t\t\t\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t\t\t\t\t//var jcmcStr = $.founded(sksj[qsjc].rsdjcmc)?sksj[qsjc].rsdjcmc:sksj[qsjc].jcmc;\n\t\t\t\t\t\t\t\t\t\t\tvar jcmcStr = $.founded(sksj[qsjc].rsdjcmc)?sksj[qsjc].rsdjcmc+(rsdzjs>1?k:''):sksj[qsjc].jcmc;\n\t\t\t\t\t\t\t\t\t\t\tif(zckbsfxssj=='1'){\n\t\t\t\t\t\t\t\t\t\t\t\thtml_table+='<td >'+jcmcStr+'</br>'+sksj[qsjc].qssj+'</br>'+sksj[qsjc].jssj+'</td>';\n\t\t\t\t\t\t\t\t\t\t\t}else{\n\t\t\t\t\t\t\t\t\t\t\t\thtml_table+='<td >'+jcmcStr+'</br>'+'</td>';\n\t\t\t\t\t\t\t\t\t\t\t}\t\n\t\t\t\t\t\t\t\t\t\t\tif(kblx==7 && qsxqj==7){\n\t\t\t\t\t\t\t\t\t\t\t\thtml_table+=\"<td rowspan=1 id = '\"+'td_'+\"7\"+\"-\"+sksj[qsjc].jcmc+\"' data = '\"+sksj[qsjc].jcmc+\"'></td>\";\n\t\t\t\t\t\t\t\t\t\t\t\tfor(var i = 1;i<=6;i++){\n\t\t\t\t\t\t\t\t\t\t\t\t\thtml_table+=\"<td  id = '\"+'td_'+i+\"-\"+sksj[qsjc].jcmc+\"' data = '\"+sksj[qsjc].jcmc+\"'></td>\";\n\t\t\t\t\t\t\t\t\t\t\t\t}\n\t\t\t\t\t\t\t\t\t\t\t}else{\n\t\t\t\t\t\t\t\t\t\t\t\tfor(var i = 1;i<=kblx;i++){\n\t\t\t\t\t\t\t\t\t\t\t\t\thtml_table+=\"<td rowspan=1 id =