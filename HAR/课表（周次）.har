            "text": ".left {\r\n\tfloat: left;\r\n}\r\n\r\n.right {\r\n\tfloat: right;\r\n}\r\n\r\n.mui-btn-block {\r\n\twidth: 92%;\r\n\tmargin-left: 4%;\r\n}\r\n\r\n.yyxz {\r\n\tpadding: 15px 18px;\r\n\ttext-align: center;\r\n\tmax-height: 500px;\r\n}\r\n\r\n.yyxz p {\r\n\tcolor: #555;\r\n}\r\n\r\n.yyxz .title {\r\n\tfont-size: 20px;\r\n\tfont-weight: 600;\r\n\tline-height: 40px;\r\n}\r\n\r\n.yyxz .content {\r\n\ttext-indent: 27px;\r\n\ttext-align: left;\r\n}\r\n\r\n.layui-layer,\r\n.layui-layer-title {\r\n\tborder-radius: 10px !important;\r\n}\r\n\r\n.mui-bar {\r\n\tbackground-color: #51B3FC;\r\n}\r\n\r\n.mui-btn-blue {\r\n\tbackground-color: #51B3FC;\r\n\tborder-color: #51B3FC;\r\n}\r\n\r\n.mui-bar-nav a,\r\n.mui-bar-nav h1 {\r\n\tcolor: #fff;\r\n}\r\n\r\n.mui-slider {\r\n\tbackground-color: #fff;\r\n}\r\n\r\n.mui-segmented-control.mui-segmented-control-inverted~.mui-slider-progress-bar {\r\n\tbackground-color: #51B3FC;\r\n}\r\n\r\n.mui-segmented-control.mui-segmented-control-inverted .mui-control-item {\r\n\tcolor: #777;\r\n}\r\n\r\n.mui-segmented-control.mui-segmented-control-inverted .mui-control-item.mui-active {\r\n\tcolor: #51B3FC;\r\n}\r\n\r\n.block .title {\r\n\tfont-size: 15px;\r\n\tcolor: #000;\r\n\tline-height: 35px;\r\n}\r\n\r\n.block .item {\r\n\tline-height: 40px;\r\n\tfont-size: 15px;\r\n}\r\n\r\n.block .item .left {\r\n\tcolor: #989898;\r\n}\r\n\r\n.block .item .right {\r\n\tcolor: #434343;\r\n}\r\n\r\n.djksbm .button-item {\r\n\tborder-top: 1px solid #ddd;\r\n\tpadding: 20px 0 0 0;\r\n}\r\n\r\n.djksbm .mui-table-view-cell:after {\r\n\tbackground-color: transparent;\r\n}\r\n\r\n.djksbm .mui-table-view-cell {\r\n\tborder-bottom: 10px solid #EFEFF4;\r\n}\r\n\r\n.bmxx .mes-block {\r\n\tbackground-color: #fff;\r\n\ttext-align: center;\r\n\tmargin-bottom: 10px;\r\n\tpadding: 10px;\r\n}\r\n\r\n.bmxx .mes-block img {\r\n\twidth: 80px;\r\n}\r\n\r\n.bmxx .mes-block .name {\r\n\tfont-size: 16px;\r\n\tline-height: 40px;\r\n}\r\n\r\n.bmxx .mes-block .number {\r\n\tcolor: #999;\r\n\tfont-size: 14px;\r\n}\r\n\r\n.bmxx .item .left {\r\n\tfont-size: 16px;\r\n}\r\n\r\n.bmxx .item .right {\r\n\tfont-size: 16px;\r\n\tcolor: #999;\r\n}\r\n\r\n.bmxx .mui-btn-block {\r\n\tmargin-top: 15px;\r\n\tpadding: 10px 0;\r\n\tborder-radius: 20px;\r\n}\r\n\r\n.lcgz .dot {\r\n\tdisplay: block;\r\n\twidth: 25px;\r\n\theight: 25px;\r\n\tbackground-color: #989898;\r\n\tborder-radius: 100%;\r\n\tborder: 2px solid #fff;\r\n\tmargin: auto;\r\n}\r\n\r\n.lcgz .line {\r\n\twidth: 1px;\r\n\tbackground-color: #999;\r\n\tmargin: auto;\r\n\theight: 90px;\r\n}\r\n\r\n.lcgz .item {\r\n\tpadding: 0 15px 0 0;\r\n}\r\n\r\n.lcgz .item.active .dot {\r\n\tbackground-color: #26BF83;\r\n}\r\n\r\n.lcgz .item.active .status {\r\n\tcolor: #26BF83;\r\n}\r\n\r\n.lcgz .item.fail .dot {\r\n\tbackground-color: #e4360a;\r\n}\r\n\r\n.lcgz .item.fail .status {\r\n\tcolor: #e4360a;\r\n}\r\n.lcgz .item:first-child {\r\n\tpadding-top: 30px;\r\n}\r\n\r\n.lcgz .item: first-child .content {\r\n\tbackground-color: transparent;\r\n}\r\n\r\n.lcgz .item:first-child .dot {\r\n\twidth: 20px;\r\n\theight: 20px;\r\n}\r\n\r\n.lcgz .item:first-child .line {\r\n\theight: 50px;\r\n}\r\n\r\n.lcgz .item:first-child .status {\r\n\tfont-size: 15px;\r\n\tcolor: #999;\r\n}\r\n\r\n.lcgz .content {\r\n\tbackground-color: #fff;\r\n\twidth: 85%;\r\n\tpadding: 0 15px;\r\n\tborder-radius: 15px;\r\n}\r\n\r\n.lcgz .sh {\r\n\tfont-size: 18px;\r\n\tline-height: 30px;\r\n}\r\n\r\n.lcgz .status,\r\n.lcgz .date {\r\n\tcolor: #999;\r\n\tfont-size: 15px;\r\n\tline-height: 30px;\r\n}\r\n\r\n.lcgz .progress {\r\n\twidth: 15%;\r\n}\r\n\r\n.ydcx .title {\r\n\tfont-size: 16px;\r\n\tcolor: #000;\r\n\tline-height: 35px;\r\n}\r\n\r\n.ydcx .title .tag {\r\n\tborder: 1px solid #ddd;\r\n\tfont-size: 12px;\r\n\tpadding: 1px 5px;\r\n\tmargin-left: 15px;\r\n}\r\n\r\n.ydcx .title .tag-yellow {\r\n\tborder-color: #F6BB3F;\r\n\tcolor: #F6BB3F;\r\n}\r\n\r\n.ydcx .title .tag-success {\r\n\tborder-color: #39C690;\r\n\tcolor: #39C690;\r\n}\r\n\r\n.ydcx .title .tag-fail{\r\n\tborder-color: #e4360a;\r\n\tcolor: #e4360a;\r\n}\r\n\r\n.ydcx .mui-table-view-cell:after {\r\n\tbackground-color: transparent;\r\n}\r\n\r\n.ydcx .opreat {\r\n\tborder-top: 1px solid #ddd;\r\n\tpadding: 10px 0 0 0;\r\n\tmargin-top: 10px;\r\n}\r\n\r\n.ydcx .xq,\r\n.ydcx .time {\r\n\tcolor: #666;\r\n\tline-height: 30px;\r\n\tfont-size: 15px;\r\n}\r\n\r\n.ydcx .mui-table-view {\r\n\tbackground-color: #EFEFF4;\r\n}\r\n\r\n.ydcx .mui-table-view-cell {\r\n\tbackground-color: #fff;\r\n\tmargin-bottom: 10px;\r\n\tborder-bottom: 1px solid #c8c7cc;\r\n\tborder-top: 1px solid #c8c7cc;\r\n}\r\n\r\n.ydcx .mui-table-view:before{\r\n\tbackground-color: transparent;\r\n}\r\n\r\n.ydxx .title{\r\n\tborder-bottom: 1px solid #d0d0d0;\r\n    font-weight: 600;\r\n    color: #555;\r\n    line-height: 40px;\r\n}\r\n\r\n.ydxx .item{\r\n\tline-height: 35px;\r\n}\r\n\r\n\r\n.ydxx .mui-table-view{\r\n\tbackground-color: #EFEFF4;\r\n}\r\n\r\n.ydxx .mui-table-view-cell{\r\n\tbackground-color: #fff;\r\n\tmargin-bottom: 10px;\r\n\tborder-top: 1px solid #ddd;\r\n\tborder-bottom: 1px solid #ddd;\r\n}\r\n\r\n.ydxx .mui-table-view-cell:after,\r\n.ydxx .mui-table-view:before,\r\n.ydxx .mui-table-view:after{\r\n\tbackground-color: transparent;\r\n}\r\n/*add*/\r\n.bmxx .item .right .no-border-input{\r\n\tborder: 0px;\r\n    margin-bottom: 0px;\r\n    height: 22px;\r\n    text-align: right;\r\n    padding-right: 0px;\r\n}\r\n/**ljw 重置确定*/\r\n.btn-box{\r\n\tpadding:10px 0px 10px 0;\r\n}\r\n.btn-box button{\r\n\tpadding:3px 12px;\r\n\tline-height: 1.5!important;\r\n}\r\n\r\n/**新版流程跟踪*/\r\n.newLcgz .nr-box{\r\n\tpadding-top:15px;\r\n\r\n}\r\n.newLcgz .dot {\r\n\tdisplay: block;\r\n\twidth: 25px;\r\n\theight: 25px;\r\n\tbackground-color: #989898;\r\n\tborder-radius: 100%;\r\n\tborder: 2px solid #fff;\r\n\tmargin: auto;\r\n}\r\n\r\n.newLcgz .line {\r\n\twidth: 1px;\r\n\tbackground-color: #999;\r\n\tmargin: auto;\r\n\theight: calc(100% - 33px);\r\n\tmargin-top: 5px;\r\n}\r\n\r\n.newLcgz .item {\r\n\tpadding: 0 15px 0 0;\r\n\tdisplay: flex;\r\n}\r\n\r\n.newLcgz .item.active .dot {\r\n\tbackground-color: #07c160;\r\n}\r\n\r\n\r\n.newLcgz .item.fail .dot {\r\n\tbackground-color: #e4360a;\r\n}\r\n\r\n.newLcgz .item.fail .status {\r\n\tcolor: #e4360a;\r\n}\r\n/* .newLcgz .item:first-child {\r\n\tpadding-top: 30px;\r\n} */\r\n\r\n/* .newLcgz .item: first-child .content {\r\n\tbackground-color: transparent;\r\n} */\r\n\r\n\r\n/* .newLcgz .item:first-child .status {\r\n\tfont-size: 13px;\r\n\tcolor: #999;\r\n} */\r\n\r\n.newLcgz .content {\r\n\tbackground-color: #fff;\r\n\twidth: 85%;\r\n\tpadding: 0 15px;\r\n\tborder-radius: 15px;\r\n\tmargin-bottom: 20px;\r\n\tmin-height: 80px;\r\n}\r\n\r\n.newLcgz .sh {\r\n\tfont-size: 16px;\r\n\tline-height: 30px;\r\n}\r\n\r\n.newLcgz .status,\r\n\r\n.newLcgz .progress {\r\n\twidth: 15%;\r\n}\r\n\r\n.newLcgz .item.red .dot{\r\n\tbackground-color: #FF4D63;\r\n\r\n}\r\n.newLcgz .item.gray .dot{\r\n\tbackground-color: #989898;\r\n\r\n}\r\n.newLcgz .top-name{\r\n\tdisplay: flex;justify-content: space-between;\r\n}\r\n.newLcgz .top-name .sh{\r\n\tflex:1;\r\n}\r\n.newLcgz .top-name .date{\r\n\twidth: 30%;\r\n\tcolor: #999;\r\n\tfont-size: 15px;\r\n\tline-height: 30px;\r\n}\r\n.newLcgz .czr-box{\r\n\tdisplay: flex;\r\n\tjustify-content: space-between;\r\n}\r\n.newLcgz .czr-box .ostatusClass{\r\n\tcolor: #999;\r\n\tfont-size: 13px;\r\n}\r\n.newLcgz .tg-class{\r\n\tpadding: 12px;\r\n    margin-top: 4px;\r\n    border-radius: 4px;\r\n    background: #29CC7819;\r\n    color: #000000CC;\r\n    font-size: 13px;\r\n\tmargin-bottom: 15px;\r\n}\r\n.newLcgz .th-class{\r\n\tbackground: #FF4D6319;\r\n}\r\n"
