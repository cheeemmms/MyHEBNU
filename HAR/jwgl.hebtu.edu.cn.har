.left-aside').find('.children-' + aid).css('display', 'none')\n\t\tthat.find('i').removeClass('arrow-expand').addClass('arrow')\n\t}else{\n\t//展开\n\t\tthat.closest('.left-aside').find('>div i').removeClass('arrow-expand').addClass('arrow')\n\t\tthat.closest('.left-aside').find('.children-' + aid).css('display', 'flex')\n\t\tthat.find('i').removeClass('arrow').addClass('arrow-expand')\n\t}\n\n\tif(url){\n\t\t//新开窗口弹出页面\n\t\topenWin('..'+url,{gnmkdm:gnmkdm},true);\n\t}\n\tcurrExpand = aid;\n})\n\n$('.iframe-tab-index').css('background', '#e2f1ff');\n\n//上侧菜单右键点击出现\n$('.iframe-tabs').on('contextmenu', '.iframe-tab-item', function(){\n  var aid =  $(this).data('aid');\n  $(this).parents('.iframe-tabs').find('.iframe-tab-item').each(function(index,item){\n    $(item).find('.close-box').css('display','none')\n  })\n  $(this).find('.close-box').css('display','block');\n  $(this).find('.close-box .close-left').removeClass('dis')\n  $(this).find('.close-box .close-right').removeClass('dis')\n  if(aid!=activeAid){\n\t  //左侧右侧都置灰\n\t  $(this).find('.close-box .close-left').addClass('dis')\n\t  $(this).find('.close-box .close-right').addClass('dis')\n  }\n  event.stopPropagation()\n  return false\n});\n//关闭全部 关闭左侧 关闭右侧\n$('.iframe-tabs').on('click', '.iframe-tab-item .close-box>div', function(){\n\tlet that = $(this);\n\tif(that.hasClass('dis')){\n\t\treturn\n\t}\n\tvar aid = $(this).parents('.iframe-tab-item').data('aid');\n    var ids = []\n\t$(this).parents('.iframe-tabs').find('.iframe-tab-item').each(function(index,item){\n\t\tids.push($(item).data('aid'));\n\t})\n\tlet num = ids.indexOf(aid);\n\n\tiframeList=[];\n\tif(that.hasClass('close-all')){\n\t\t//只展示首页\n\t\tactiveAid = aid;\n\t\tif(ids && ids.length){\n\t\t\tids.forEach(function(item,index){\n\t\t\t\tconsole.log(that.parents('.iframe-container'))\n\t\t\t\tif(item!=='index'){\n\t\t\t\t\tthat.parents('.iframe-container').find('.iframe-inner-' + item).remove()\n\t\t\t\t\tthat.parents('.iframe-tabs').find('.iframe-tab-' + item).remove();\n\t\t\t\t\tvar ind = tabsList.findIndex(itemp=>itemp.aid==item);\n\t\t\t\t\ttabsList.splice(ind,1)\n\t\t\t\t}else{\n\t\t\t\t\tiframeList.push(item);\n\t\t\t\t\tthat.parents('.iframe-container').find('.iframe-inner-' + item).css('display', 'block')\n\t\t\t\t}\n\t\t\t})\n\t\t}\n\t\t$('.left-aside-item-children').css('display', 'none')\n\t\t$('.left-aside-item-children-children').css('display', 'none')\n\t\t$('#left-aside>div').removeClass('choseBk');\n\n\t\t//箭头复原\n\t\t$('#left-aside>div').each(function(index,item){\n\t\t\t$(item).find('i').removeClass('arrow-expand').addClass('arrow');\n\t\t})\n\t\tcurrExpand = null;\n\t\tconsole.log('关闭全部');\n\t}\n\t//关闭左边\n\tif(that.hasClass('close-left')){\n\t\tif(ids && ids.length){\n\t\t\tids.forEach(function(item,index){\n\t\t\t\tif(index<num && item!='index'){\n\t\t\t\t\tthat.parents('.iframe-container').find('.iframe-inner-' + item).remove()\n\t\t\t\t\tthat.parents('.iframe-tabs').find('.iframe-tab-' + item).remove();\n\t\t\t\t\tvar ind = tabsList.findIndex(itemp=>itemp.aid==item);\n\t\t\t\t\ttabsList.splice(ind,1)\n\t\t\t\t}else{\n\t\t\t\t\tiframeList.push(item);\n\t\t\t\t}\n\t\t\t})\n\t    }\n\t\tconsole.log('关闭左边');\n\t}\n\t//关闭右边\n\tif(that.hasClass('close-right')){\n\t\tif(ids && ids.length){\n\t\t\tids.forEach(function(item,index){\n\t\t\t\tif(index>num && item!='index'){\n\t\t\t\t\tthat.parents('.iframe-container').find('.iframe-inner-' + item).remove()\n\t\t\t\t\tthat.parents('.iframe-tabs').find('.iframe-tab-' + item).remove();\n\t\t\t\t\tvar ind = tabsList.findIndex(itemp=>itemp.aid==item);\n\t\t\t\t\ttabsList.splice(ind,1)\n\t\t\t\t}else{\n\t\t\t\t\tiframeList.push(item);\n\t\t\t\t}\n\t\t\t})\n    \t}\n\t\tconsole.log('关闭右边');\n\t}\n\tthat.parent().css('display','none');\n\tevent.stopPropagation()\n\tinitTabs(tabsList);\n})\n\n$(document).on('hover', '.iframe-tab-item', function() {\n\tvar aid = $(this).data('aid')\n\t$('.close-tab-' + aid).css('display', 'inline');\n\t//$('.tab-text-' + aid).css('display', 'none');\n\tif (this.style.background !== 'rgb(226, 241, 255)') {\n\t    $(this).css('background', '#DDD')\n\t \t$(this).css('color', '#333')\n\t\t$('.close-tab-' + aid).css('color', '#333')\n\t}\n})\n\n$(document).on('mouseleave', '.iframe-tab-item', function() {\n\tvar aid = $(this).data('aid')\n\tconsole.log('.close-tab-' + aid)\n\t$('.close-tab-' + aid).css('display', 'none')\n\t$('.close-tab-' + aid).css('color', '#0483d4')\n\t$(this).css('color', '#0483d4');\n\t//$('.tab-text-' + aid).css('display', 'inline-block');\n\tif (this.style.background !== 'rgb(226, 241, 255)') {\n\t\t$(this).css('background', '#FFF')\n\t};\n\t$(this).parent('.iframe-tabs').find('.iframe-tab-item').each(function(index,item){\n     $(item).find('.close-box').css('display','none')\n    })\n})\n/** 点关闭*/\n$(document).on('click', '.close-tab', function(event) {\n\tvar aid = $(this).data('aid')\n\tconsole.log(aid,'点.close-tab')\n\t$(this).remove();\n\t$('.iframe-tab-' + aid).remove();\n\t$('.iframe-inner-' + aid).remove();\n\tvar iframeListTmp = [];\n\tfor (var i = 0; i < iframeList.length; i++) {\n\t\tif (iframeList[i] !== aid) {\n\t\t\tiframeListTmp.push(iframeList[i])\n\t\t} else if (activeAid === aid) {\n\t\t\tactiveAid = iframeListTmp[iframeListTmp.length - 1]\n\t\t\t$('.iframe-inner-' + activeAid).css('display', 'block');\n\t\t\t$('.iframe-tab-' + activeAid).css('background', '#e2f1ff');\n\t\t}\n\t}\n\tiframeList = iframeListTmp\n\tevent.stopPropagation()\n\tvar ind = tabsList.findIndex(item=>item.aid==aid);\n\ttabsList.splice(ind,1);\n\tinitTabs(tabsList);\n})\n\n//点左侧二级菜单\n$(document).on('click', '.left-aside-item-children', function() {\n\t// var aid = $(this).data('aid')\n\t// if(!$(this).find('i').length){\n    //   $('#left-aside>div').removeClass('choseBk');\n\t//   $(this).addClass('choseBk');\n\t// }\n\t// $('.left-aside-item-children-children').css('display', 'none')\n\t// if (currExpand + '' !== aid + '') {\n\t// \t$('.children-' + aid).css('display', 'flex')\