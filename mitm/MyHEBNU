function checkTabOverflow() {
  var $tabWrapper = $('.tab-wrapper');
  var $tabsContainer = $('.iframe-tabs');
  var $tabOverflow = $('.tab-overflow');
  var $tabDropdown = $('.tab-dropdown');

  // ķćŹńĮ«ńŖČµĆü
  $tabOverflow.hide();
  $tabsContainer.children().show().appendTo($tabsContainer);
  $tabDropdown.empty();

  // ĶÄĘÕÅ¢Õ«╣ÕÖ©Õ«ĮÕ║”
  var containerWidth = $tabWrapper.width();
  let totalWidth = 0;
  let visibleTabs = [];
  let hiddenTabs = [];

  // Ķ«Īń«ŚÕÅ»Ķ¦üµĀćńŁŠ
  $tabsContainer.children().each(function() {
    var $tab = $(this);
    var tabWidth = $tab.outerWidth(true);

    if (totalWidth + tabWidth + 30 <= containerWidth) { // 40µś»ńĢÖń╗Öµø┤ÕżÜµīēķÆ«ńÜäń®║ķŚ┤
      totalWidth += tabWidth;
      visibleTabs.push($tab);
    } else {
      hiddenTabs.push($tab);
    }
  });

  // Õ”éµ×£µ£ēķÜÉĶŚÅńÜäµĀćńŁŠ’╝īµśŠńż║µø┤ÕżÜµīēķÆ«
  if (hiddenTabs.length > 0) {
    $tabOverflow.show();

