 \t\t\t\t\t\t//$('.iframe-container').append('<iframe class=\"iframe-inner iframe-inner-' + aid + '\" src=\"http://127.0.0.1/jwglxt/' + menuRes[i].children[j].url + '\" />')\n\t// \t\t\t\t\t\t$('.iframe-container').append('<iframe onload=\"ifFun()\" class=\"iframe-inner iframe-inner-' + aid + '\" src=\"' + window.location.href.split('jwglxt')[0] + 'jwglxt' + menuRes[i].children[j].url + '\" />')\n\t// \t\t\t\t\t\t// $('.iframe-container').append('<iframe class=\"iframe-inner iframe-inner-' + aid + '\" />')\n\n\t// \t\t\t\t\t\tvar link = menuRes[i].children[j].url\n\t// \t\t\t\t\t\tvar name = menuRes[i].children[j].name\n\t// \t\t\t\t\t// setTimeout(function(){\n\t// \t\t\t\t\t\t// $('.iframe-container iframe-inner-' + aid + '').attr('src',window.location.href.split('jwglxt')[0] + 'jwglxt' + link)\n\t// \t\t\t\t\t\tiframeList.push(aid)\n\t// \t\t\t\t\t\t//$('.iframe-tabs').append('<div class=\"iframe-tab-item iframe-tab-' + aid + '\" data-aid=\"' + aid + '\"><span class=\"tab-text tab-text-' + aid + '\">' + menuRes[i].children[j].name + '</span><span class=\"close-tab close-tab-' + aid + '\" data-aid=\"' + aid + '\">x</span></div>');\n\t// \t\t\t\t\t\t$('.iframe-tabs').append(\n\t// \t\t\t\t\t\t'<div class=\"iframe-tab-item iframe-tab-' + aid + '\" data-aid=\"' + aid + '\">'+\n\t// \t\t\t\t\t\t\t'<span class=\"tab-text tab-text-' + aid + '\">' + name + '</span>'+\n\t// \t\t\t\t\t\t\t'<span class=\"close-tab close-tab-' + aid + '\" data-aid=\"' + aid + '\">x</span>'+\n\t// \t\t\t\t\t\t\t'<div class=\"close-box\"><div class=\"close-all\">关闭全部</div><div class=\"close-left\">关闭左侧</div><div class=\"close-right\">关闭右边</div></div>'+\n\t// \t\t\t\t\t\t\t'</div>');\n\t// \t\t\t\t\t\t\ttabsList.push({aid: aid,name: name })\n\t// \t\t\t\t\t\t\tinitTabs(tabsList);\n\t// \t\t\t\t\t// })\n\n\t// \t\t\t\t\t} else {\n\t// \t\t\t\t\t\t$('.iframe-inner-' + aid).css('display', 'block')\n\t// \t\t\t\t\t}\n\t// \t\t\t\t\t$('.iframe-tab-' + aid).css('background', '#e2f1ff');\n\n\t// \t\t\t\t}\n\t// \t\t\t}\n\t// \t\t}\n\t// \t}\n\t// }\n\n\t// if (currExpand !== aid) {\n\t// \tcurrExpand = aid\n\t// } else {\n\t// \tcurrExpand = aid.split('-')[0]\n\t// }\n\n\tvar aid = $(this).data('aid'),that = $(this);\n\tconsole.log(aid,'二级aid')\n\tif(!$(this).find('i').length){\n      $('#left-aside>div').removeClass('choseBk');\n\t  $(this).addClass('choseBk');\n\t}\n\t$(this).closest('.left-aside').find('.left-aside-item-children-children').css('display', 'none')\n\n\tfor (var i = 0; i < menuRes.length; i++) {\n\t\tif (menuRes[i].propertyIsEnumerable('children') && menuRes[i].children.length > 0) {\n\t\t\t$('.item-' + i).find('i').removeClass('arrow-expand').addClass('arrow');\n\t\t}\n\t\tif (menuRes[i].propertyIsEnumerable('children')) {\n\t\t\tfor (var j = 0; j < menuRes[i].children.length; j++) {\n\t\t\t\tif (menuRes[i].children[j].propertyIsEnumerable('children') && menuRes[i].children[j].children.length > 0) {\n\t\t\t\t\t//有三级\n\t\t\t\t\tif(aid === (i + '-' + j)){\n\t\t\t\t\t\t//一级图标展开\n\t\t\t\t\t\t$('.item-' + i).find('i').removeClass('arrow').addClass('arrow-expand');\n\t\t\t\t\t\tif(currExpand !== aid){\n\t\t\t\t\t\t\t//显示三级item\n\t\t\t\t\t\t\t$('.children-' + aid).css('display', 'flex')\n\t\t\t\t\t\t\t//二级图标展开\n\t\t\t\t\t\t\t$('.item-' + aid).find('i').removeClass('arrow').addClass('arrow-expand');\n\t\t\t\t\t\t}else{\n\t\t\t\t\t\t\tif($('.item-' + aid).find('i').hasClass('arrow-expand')){\n\t\t\t\t\t\t\t\t//收起\n\t\t\t\t\t\t\t\t$('.children-' + aid).css('display', 'none')\n\t\t\t\t\t\t\t\t$('.item-' + aid).find('i').removeClass('arrow-expand').addClass('arrow')\n\t\t\t\t\t\t\t}else{\n\t\t\t\t\t\t\t\t//展开\n\t\t\t\t\t\t\t\t$('.children-' + aid).css('display', 'flex')\n\t\t\t\t\t\t\t\t$('.item-' + aid).find('i').removeClass('arrow').addClass('arrow-expand')\n\t\t\t\t\t\t\t}\n\t\t\t\t\t\t}\n\t\t\t\t\t}else{\n\t\t\t\t\t\t$('.item-' + (i + '-' + j)).find('i').removeClass('arrow-expand').addClass('arrow')\n\t\t\t\t\t}\n\t\t\t\t} else {\n\t\t\t\t\t//无三级\n\t\t