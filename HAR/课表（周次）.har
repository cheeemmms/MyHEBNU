            "size": 14976,
            "mimeType": "application/javascript",
            "text": "(function(b) {\r\n    b.bootui = b.bootui || {};\r\n    b.bootui.widget = b.bootui.widget || {};\r\n    b.bootui.widget.Typeahead = function(d, c) {\r\n        c.beforeRender.call(this, d);\r\n        try {\r\n            this.initialize.call(this, d, c)\r\n        } catch (f) {\r\n            c.errorRender.call(this, f)\r\n        }\r\n        c.afterRender.call(this, d)\r\n    }\r\n    ;\r\n    b.bootui.widget.Typeahead.prototype = {\r\n        constructor: b.bootui.widget.Typeahead,\r\n        initialize: function(d, c) {\r\n            var e = this;\r\n            this.$element = b(d);\r\n            this.parentElement = c.idDom || this.$element.closest('.modal-content')\r\n            this.options = c;\r\n            this.sorter = this.options.sorter || this.sorter;\r\n            this.highlighter = this.options.highlighter || this.highlighter;\r\n            this.updater = this.options.updater || this.updater;\r\n            this.source = this.options.source;\r\n            this.$menu = b(this.options.menu);\r\n            this.shown = false;\r\n            this.formatItem = this.options.formatItem || this.formatItem;\r\n            this.setValue = this.options.setValue || this.setValue;\r\n            this.$element.on(\"focus\", b.proxy(this.focus, this)).on(\"blur\", b.proxy(this.blur, this)).on(\"keypress\", b.proxy(this.keypress, this)).on(\"keyup\", b.proxy(this.keyup, this));\r\n            if (this.eventSupported(\"keydown\")) {\r\n                this.$element.on(\"keydown\", b.proxy(this.keydown, this))\r\n            }\r\n            this.$menu.css({\r\n                \"min-width\": b(d).outerWidth()\r\n            }).on(\"click\", b.proxy(this.click, this)).on(\"mouseenter\", \"li\", b.proxy(this.mouseenter, this)).on(\"mouseleave\", \"li\", b.proxy(this.mouseleave, this))\r\n            this.$menu.on(\"mouseenter\", b.proxy(this.menuMouseEnter, this)).on(\"mouseleave\", b.proxy(this.menuMouseLeave, this))\r\n        },\r\n        destroy: function() {\r\n            this.$element.off(\".typeahead\").removeData(\"bootui.typeahead\")\r\n        },\r\n        setDefaults: function(c) {\r\n            b.extend(b.fn.typeahead.defaults, c)\r\n        },\r\n        processObj: 0,\r\n        formatItem: function(c) {\r\n            return c.toString()\r\n        },\r\n        setValue: function(c) {\r\n            return {\r\n                \"data-value\": c.toString(),\r\n                \"real-value\": c.toString()\r\n            }\r\n        },\r\n        select: function() {\r\n            var d = this.$menu.find(\".active\").attr(\"data-value\");\r\n            var c = this.$menu.find(\".active\").attr(\"real-value\");\r\n            this.$element.val(this.updater(d)).attr(\"real-value\", c).change();\r\n            return this.hide()\r\n        },\r\n        updater: function(c) {\r\n            return c\r\n        },\r\n        comOffset: function(){\r\n            var ist = false; //是否放的下 true放不下 右定位\r\n            if(this.parentElement && this.parentElement.length){\r\n                var parentOffset = this.parentElement.offset();\r\n                var parentWidth = this.parentElement.outerWidth();\r\n                var childOffset = this.$element.offset();\r\n                var childWidth = this.$element.outerWidth();\r\n                //计算子元素相对于父元素左边框的距离\r\n                var toLeftEdge = childOffset.left - parentOffset.left;\r\n                //计算子元素的左边框相对于父元素右边框的距离\r\n                 // var rightJl = parentOffset.left + parentWidth - (childOffset.left + childWidth);\r\n                var toRightEdge = parentOffset.left + parentWidth - (childOffset.left);\r\n                // console.log(toRightEdge,this.$menu.outerWidth(),'===')\r\n                if(toRightEdge - 15 < this.$menu.outerWidth()){\r\n                    ist = true\r\n                }\r\n            }\r\n            return ist;\r\n        },\r\n        show: function() {\r\n            var that = this;\r\n            var e = b.extend({}, that.$element.position(), {\r\n            height: that.$element[0].offsetHeight\r\n            });\r\n            that.$menu.insertAfter(that.$element);\r\n            var ist =  that.comOffset();\r\n            var d = that.$element.closest(\".bootbox\");\r\n            var c = 1010;\r\n\r\n            if (b(d).size() > 0) {\r\n                c = (parseInt(d.css(\"z-index\") || \"1050\") + 90);\r\n                let cssPar = {\r\n                    \"z-index\": c,\r\n                    top: e.top + e.height,\r\n                    left: 'auto',\r\n                    right: 'auto'\r\n                }\r\n                if(ist){\r\n                    cssPar.right = '0'\r\n                }else{\r\n                    cssPar.left = e.left\r\n                }\r\n                that.$menu.css(cssPar).show()\r\n                b(d).find(\".chosen-container\").css(\"z-index\", --c)\r\n            } else {\r\n                let cssPar = {\r\n                    \"z-index\": \"1010\",\r\n                    top: e.top + e.height,\r\n                    left: 'auto',\r\n                    right: 'auto'\r\n                }\r\n                if(ist){\r\n                    cssPar.right = '0'\r\n                }else{\r\n                    cssPar.left = e.left\r\n                }\r\n                that.$menu.css(cssPar).show()\r\n                that.$element.css(\"z-index\", \"1010\");\r\n                b(\".chosen-container\").css(\"z-index\", --c)\r\n            }\r\n            that.shown = true;\r\n            return that\r\n        },\r\n        hide: function() {\r\n            this.$menu.hide();\r\n            this.shown = false;\r\n            return this\r\n        },\r\n        lookup: function(d) {\r\n            var c;\r\n            this.query = this.$element.val();\r\n            if (!this.query || this.query.length < this.options.minLength) {\r\n                return this.shown ? this.hide() : this\r\n            }\r\n            c = b.isFunction(this.source) ? this.source(this.query, b.proxy(this.process, this)) : this.source;\r\n            return c ? this.process(c) : this\r\n        },\r\n        process: function(c) {\r\n            var d = this;\r\n            if (!c.length) {\r\n                return this.shown ? this.hide() : this\r\n            }\r\n            var newlength = typeof this.options.items == 'number'?this.options.items: c.length\r\n            return this.render(c.slice(0, newlength)).show()\r\n        },\r\n        highlighter: function(d) {\r\n            var c = this;\r\n            d = c.formatItem(d);\r\n            var e = this.query.replace(/[\\-\\[\\]{}()*+?.,\\\\\\^$|#\\s]/g, \"\\\\$&\");\r\n            return d.replace(new RegExp(\"(\" + e + \")\",\"ig\"), function(f, g) {\r\n                return '<strong style=\"color:#FF6600;\">' + g + \"</strong>\"\r\n            })\r\n        },\r\n        render: function(c) {\r\n            var d = this;\r\n            c = b(c).map(function(e, f) {\r\n                e = b(d.options.item).attr(d.setValue(f));\r\n                e.find(\"a\").html(d.highlighter(f));\r\n                return e[0]\r\n            });\r\n            c.first().addClass(\"active\");\r\n            this.$menu.html(c);\r\n            return this\r\n        },\r\n        scrollFun:function(c,type){\r\n            var maxHei = parseFloat(this.$menu.css('max-height'))\r\n\r\n            const f = b(this.$menu.find(\"li\")[0])\r\n\r\n            // 获取 ul 的 offset().top 值\r\n            const menuTop = this.$menu.offset().top;\r\n\r\n            // 获取第一个 li 的 offset().top 值\r\n            const fLiTop = f.offset().top;\r\n\r\n            // 获取选中 li 的 offset().top 值\r\n            const cLiTop = c.offset().top;\r\n\r\n            // 计算第一个 li 相对于 ul 的垂直距离\r\n            const firstLiRelativeTop = fLiTop - menuTop;\r\n\r\n            // 计算选中 li 相对于 ul 的垂直距离\r\n            const fifthLiRelativeTop = cLiTop - menuTop;\r\n\r\n            // 计算选中 li 和第一个 li 之间的垂直距离\r\n            const verticalDistance = fifthLiRelativeTop - firstLiRelativeTop;\r\n\r\n             if(type=='next'){\r\n                var scrollTop = this.$menu.scrollTop();\r\n                // console.log(verticalDistance - scrollTop,'11')\r\n                if(verticalDistance - scrollTop<0){\r\n                     //选中值在框的上面\r\n                    scrollTop = 0;\r\n                }else{\r\n                    if((verticalDistance + c[0].offsetHeight + 15 - scrollTop)>maxHei){\r\n                        //在框的下面\r\n                        scrollTop = verticalDistance + c[0].offsetHeight + 15 - maxHei\r\n                    }\r\n                }\r\n                this.$menu.scrollTop(scrollTop)\r\n             }else{\r\n                var scrollTop = this.$menu.scrollTop();\r\n                // console.log(verticalDistance - scrollTop,'11')\r\n                if(verticalDistance - scrollTop<0){\r\n                    //选中值在框的上面\r\n                  scrollTop = verticalDistance\r\n                }else{\r\n                    if((verticalDistance - scrollTop)>maxHei){\r\n                        //在框的下面\r\n                        scrollTop = verticalDistance + c[0].offsetHeight + 15 - maxHei\r\n                    }\r\n                }\r\n                this.$menu.scrollTop(scrollTop)\r\n             }\r\n        },\r\n        next: function(d) {\r\n            var e = this.$menu.find(\".active\").removeClass(\"active\")\r\n              , c = e.next();\r\n               if (!c.length) {\r\n                c = b(this.$menu.find(\"li\")[0])\r\n            }\r\n            c.addClass(\"active\")\r\n            this.scrollFun(c,'next')\r\n        },\r\n        prev: function(d) {\r\n            var e = this.$menu.find(\".active\").removeClass(\"active\")\r\n              , c = e.prev();\r\n            if (!c.length) {\r\n                c = this.$menu.find(\"li\").last()\r\n            }\r\n            c.addClass(\"active\")\r\n            this.scrollFun(c,'prev')\r\n        },\r\n        eventSupported: function(c) {\r\n            var d = c in this.$element;\r\n            if (!d) {\r\n                this.$element.setAttribute(c, \"return;\");\r\n                d = typeof this.$element[c] === \"function\"\r\n            }\r\n            return d\r\n        },\r\n        move: function(c) {\r\n            if (!this.shown) {\r\n                return\r\n            }\r\n            switch (c.keyCode) {\r\n            case 9:\r\n            case 13:\r\n            case 27:\r\n                c.preventDefault();\r\n                break;\r\n            case 38:\r\n                c.preventDefault();\r\n                this.prev();\r\n                break;\r\n            case 40:\r\n                c.preventDefault();\r\n                this.next();\r\n                break\r\n            }\r\n            c.stopPropagation()\r\n        },\r\n        keydown: function(c) {\r\n            this.suppressKeyPressRepeat = ~b.inArray(c.keyCode, [40, 38, 9, 13, 27]);\r\n            this.move(c)\r\n        },\r\n        keypress: function(c) {\r\n            if (this.suppressKeyPressRepeat) {\r\n                return\r\n            }\r\n            this.move(c)\r\n        },\r\n        keyup: function(d) {\r\n            switch (d.keyCode) {\r\n            case 40:\r\n            case 38:\r\n            case 16:\r\n            case 17:\r\n            case 18:\r\n                break;\r\n            case 9:\r\n            case 13:\r\n                if (!this.shown) {\r\n                    return\r\n                }\r\n                this.select();\r\n                break;\r\n            case 27:\r\n                if (!this.shown) {\r\n                    return\r\n                }\r\n                this.hide();\r\n                break;\r\n            default:\r\n                var c = this;\r\n                if (c.processObj) {\r\n                    clearTimeout(c.processObj);\r\n                    c.processObj = 0\r\n                }\r\n                c.processObj = setTimeout(function() {\r\n                    c.lookup()\r\n                }, c.options.delay)\r\n            }\r\n            d.stopPropagation();\r\n            d.preventDefault()\r\n        },\r\n        focus: function(c) {\r\n            this.focused = true\r\n        },\r\n        blur: function(c) {\r\n            this.focused = false;\r\n            // console.log(this.menuMousedover,'blur1==')\r\n            if (!this.mousedover && this.shown && !this.menuMousedover) {\r\n                // console.log('blur2==')\r\n                this.hide()\r\n            }\r\n        },\r\n        click: function(c) {\r\n            c.stopPropagation();\r\n            c.preventDefault();\r\n            this.select();\r\n            this.$element.focus()\r\n        },\r\n        mouseenter: function(c) {\r\n            this.mousedover = true;\r\n            this.$menu.find(\".active\").removeClass(\"active\");\r\n            b(c.currentTarget).addClass(\"active\")\r\n        },\r\n        mouseleave: function(c) {\r\n            // console.log(this.focused,this.shown,this.menuMousedover,'leave1')\r\n            this.mousedover = false;\r\n            if (!this.focused && this.shown && !this.menuMousedover) {\r\n                // console.log('leave2')\r\n                this.hide()\r\n            }\r\n        },\r\n        menuMouseEnter:function(c){\r\n            this.menuMousedover = true;\r\n            // console.log('menuenter3')\r\n        },\r\n        menuMouseLeave:function(c){\r\n            // console.log(this.focused,this.shown,this.mousedover,'menuleave3')\r\n            this.menuMousedover = false;\r\n             if (!this.focused && this.shown && !this.mousedover) {\r\n                // console.log('menuleave4')\r\n                this.hide()\r\n            }\r\n        },\r\n    };\r\n    var a = b.fn.typeahead;\r\n    b.fn.typeahead = function(d) {\r\n        var c = b.grep(arguments || [], function(f, e) {\r\n            return e >= 1\r\n        });\r\n        return this.each(function() {\r\n            var g = b(this)\r\n              , f = g.data(\"bootui.typeahead\");\r\n            if (!f && d == \"destroy\") {\r\n                return\r\n            }\r\n            if (!f) {\r\n                var e = b.extend(true, {}, b.fn.typeahead.defaults, g.data(), ((typeof d == \"object\" && d) ? d : {}));\r\n                g.data(\"bootui.typeahead\", (f = new b.bootui.widget.Typeahead(this,e)))\r\n            }\r\n            if (typeof d == \"string\") {\r\n                f[d].apply(f, [].concat(c || []))\r\n            }\r\n        })\r\n    }\r\n    ;\r\n    b.fn.typeahead.defaults = {\r\n        version: \"1.0.0\",\r\n        beforeRender: b.noop,\r\n        errorRender: b.noop,\r\n        afterRender: b.noop,\r\n        source: [],\r\n        items: 8,\r\n        menu: '<ul class=\"typeahead dropdown-menu\" style=\"max-height:250px;overflow:auto\"></ul>',\r\n        item: '<li><a href=\"#\"></a></li>',\r\n        minLength: 1,\r\n        delay: 500\r\n    };\r\n    b.fn.typeahead.Constructor = b.bootui.widget.Typeahead;\r\n    b.fn.typeahead.noConflict = function() {\r\n        b.fn.typeahead = a;\r\n        return this\r\n    }\r\n    ;\r\n    b(document).on(\"focus.typeahead.data-api\", '[data-provide*=\"typeahead\"]', function(c) {\r\n        if (c.currentTarget = this) {\r\n            var d = b(this);\r\n            if (d.data(\"bootui.typeahead\")) {\r\n                return\r\n            } else {\r\n                d.typeahead(d.data())\r\n            }\r\n        }\r\n    })\r\n}(jQuery));\r\n"
