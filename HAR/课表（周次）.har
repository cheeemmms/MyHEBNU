            "text": ";(function ($) {\n\t$.i18n.map = $.i18n.map || {};\n\t$.extend($.i18n.map, {\n\t\t'no-xsxx' : '无您的基本信息，请与管理员联系！',\n\t\t'no-kbxx' : '该学年学期尚无您的课表！',\n\t\t'no-kbkfxx' : '该学年学期的课表尚未开放！',\n\t\t'jfhkcx' : '缴费后可查询！',\n\t\t'xnxqkbbkdy' : '该学年学期课表当前时间段不允许打印！',\n\t\t'skfsmc' : '上课方式名称',\n\t\t'kczxs' : '课程总学时',\n\t\t'bkdj' : '板块等级',\n\t\t'ckjxbtkjl' : '查看教学班调课记录',\n\t\t'sykb' : '实验课表',\n\t\t'syxmmc' : '实验项目名称',\n\t\t'syfzmc' : '实验分组名称',\n\t\t'sfyjdycdxq' : '实验房间对应场地校区',\n\t\t'syry' : '实验人员',\n\t\t'sksjdd' : '上课时间地点',\n\t\t'symc' : '实验名称',\n\t\t'sqdw' : '申请单位',\n\t\t'sbjs' : '申报教师',\n\t\t'jxdw' : '教学单位',\n\t\t'syzx' : '实验中心',\n\t\t'sys' : '实验室',\n\t\t'syslb' : '实验室类别',\n\t\t'sycd' : '实验场地',\n\t\t'kfsj' : '开放时间',\n\t\t'zdjssj' : '指导教师时间',\n\t\t'no-zcxx' : '该学年学期无您的注册信息，请与管理员联系！',\n\t\t'xnxqbyxcksjd' : '该学年学期课表当前时间段不允许查看！',\n\t\t'xnxqxx' : '{0}学年{1}学期',\n\t\t'xnxqxx2' : '{0}学年第{1}学期',\n\t\t'diao' : '调',\n\t\t'zs' : '周数',\n\t\t'skfsmc' : '授课方式名称',\n\t\t'skfs' : '授课方式',\n\t\t'rjcszyw' : '日节次设置有误',\n\t\t'kfxsykc' : '开放性实验课表',\n\t\t'hsxtwdsx' : '红色斜体为待筛选',\n\t\t'lswxs' : '蓝色为已选上',\n\t\t'dlswcxwjf' : '淡蓝色为重修未缴费',\n\t\t'sjd' : '时间段',\n\t\t'zhu' : '注',\n\t\t'djj' : '第{0}节',\n\t\t'qi' : '起',\n\t\t'zhi' : '止',\n\t\t'sjkc' : '实践课程',\n\t\t'qtkc' : '其它课程',\n\t\t'jxhj' : '教学环节',\n\t\t'xqj' : '星期',\n\t\t'kbxx' : '课表信息',\n\t\t'kbcxwk' : '课表查询结果为无课！',\n\t\t'xq1' : '周一',\n\t\t'xq2' : '周二',\n\t\t'xq3' : '周三',\n\t\t'xq4' : '周四',\n\t\t'xq5' : '周五',\n\t\t'xq6' : '周六',\n\t\t'xq7' : '周日',\n\t});\n}(jQuery))"
